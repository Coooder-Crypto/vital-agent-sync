{
  "name": "healthlink-local",
  "version": "0.1.0",
  "description": "Local HealthLink Agent server for pairing, ingest, storage, and MCP tools.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/Coooder-Crypto/health-link#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Coooder-Crypto/health-link.git",
    "directory": "packages/local"
  },
  "bugs": {
    "url": "https://github.com/Coooder-Crypto/health-link/issues"
  },
  "keywords": [
    "healthlink",
    "mcp",
    "agent",
    "apple-health",
    "hermes",
    "openclaw"
  ],
  "bin": {
    "healthlink-local": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.3.3",
    "qrcode": "^1.5.4",
    "yaml": "^2.9.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
