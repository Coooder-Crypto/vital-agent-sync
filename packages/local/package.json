{
  "name": "vitalmcp",
  "version": "0.5.2",
  "description": "Local runtime for Vital Agent Sync: private Apple Health pairing, sync, storage, and MCP tools.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/Coooder-Crypto/vital-agent-sync#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Coooder-Crypto/vital-agent-sync.git",
    "directory": "packages/local"
  },
  "bugs": {
    "url": "https://github.com/Coooder-Crypto/vital-agent-sync/issues"
  },
  "keywords": [
    "vitalmcp",
    "mcp",
    "agent",
    "apple-health",
    "healthkit",
    "hermes",
    "openclaw",
    "workbuddy",
    "tailscale",
    "local-first"
  ],
  "bin": {
    "vitalmcp": "./dist/launcher.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "relay:fixture-flow": "tsx src/relay-fixture-flow.ts",
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.3.3",
    "qrcode": "^1.5.4",
    "yaml": "^2.9.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
