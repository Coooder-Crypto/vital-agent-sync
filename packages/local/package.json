    "@types/qrcode": "^1.5.6",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.3.3",
    "qrcode": "^1.5.4",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
