{
  "name": "@healthlink/local",
  "version": "0.1.0",
  "private": true,
  "description": "Local HealthLink Agent server for pairing, ingest, storage, and MCP tools.",
  "type": "module",
  "bin": {
    "healthlink-local": "./dist/cli.js"
  },
  "files": [
    "dist",
    "public",
    "migrations",
    "README.md"
  ],
  "scripts": {
